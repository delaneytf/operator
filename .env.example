# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Atlassian OAuth (Jira + Confluence) ───────────────────────────────────────
# Register an OAuth 2.0 app at: https://developer.atlassian.com/console/myapps/
# Callback URL to register: http://localhost:3000/auth/callback/atlassian
# Scopes needed: read:jira-work write:jira-work manage:jira-project
#                read:confluence-space.summary read:confluence-content.all write:confluence-content
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Fallback: API token auth (used if OAuth not configured, or via "use API key instead")
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=you@yourcompany.com
CONFLUENCE_API_TOKEN=

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/api-keys
# Can also be set via the Integrations UI
ANTHROPIC_API_KEY=
# Model to use (defaults to claude-opus-4-7 if not set)
ANTHROPIC_MODEL=claude-opus-4-7

# ── OpenAI (ChatGPT) ──────────────────────────────────────────────────────────
# Generate at: https://platform.openai.com/api-keys
# Can also be set via the Integrations UI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Generate at: https://aistudio.google.com/app/apikey
# Can also be set via the Integrations UI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Slack OAuth ────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Callback URL to register: http://localhost:3000/auth/callback/slack
# Bot scopes needed: channels:read channels:history chat:write users:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Fallback: paste a bot token directly
SLACK_BOT_TOKEN=xoxb-

# ── Microsoft OAuth (Teams / Outlook) ─────────────────────────────────────────
# Register an app at https://portal.azure.com → App registrations
# Callback URL to register: http://localhost:3000/auth/callback/microsoft
# Uses PKCE (no client secret required for public client)
# API permissions: User.Read Calendars.Read Mail.Read
MICROSOFT_CLIENT_ID=
# Fallback: paste a Graph API access token directly
MICROSOFT_ACCESS_TOKEN=
