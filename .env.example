# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Jira (Atlassian Cloud) ─────────────────────────────────────────────────────
# Base URL of your Atlassian instance, e.g. https://your-org.atlassian.net
JIRA_BASE_URL=https://your-org.atlassian.net
# The email address you use to log in to Jira
JIRA_EMAIL=you@yourcompany.com
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ── Confluence (Atlassian Cloud) ───────────────────────────────────────────────
# For Atlassian Cloud, this is the same base URL as Jira above
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=you@yourcompany.com
# Same API token works for both Jira and Confluence on Atlassian Cloud
CONFLUENCE_API_TOKEN=

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=
# Model to use for the assistant (defaults to claude-opus-4-7 if not set)
ANTHROPIC_MODEL=claude-opus-4-7
