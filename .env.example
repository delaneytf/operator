# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Jira (Atlassian Cloud) ─────────────────────────────────────────────────────
# Can also be set via the Integrations UI — stored in data/tokens.json
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@yourcompany.com
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ── Confluence (Atlassian Cloud) ───────────────────────────────────────────────
# Same base URL and API token as Jira for Atlassian Cloud
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=you@yourcompany.com
CONFLUENCE_API_TOKEN=

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/api-keys
# Can also be set via the Integrations UI
ANTHROPIC_API_KEY=
# Model to use (defaults to claude-opus-4-7 if not set)
ANTHROPIC_MODEL=claude-opus-4-7

# ── OpenAI (ChatGPT) ──────────────────────────────────────────────────────────
# Generate at: https://platform.openai.com/api-keys
# Can also be set via the Integrations UI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Generate at: https://aistudio.google.com/app/apikey
# Can also be set via the Integrations UI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Slack ──────────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Add scopes: channels:read, channels:history, chat:write
# Install to workspace and copy Bot User OAuth Token
# Can also be set via the Integrations UI
SLACK_BOT_TOKEN=xoxb-

# ── Microsoft (Teams / Outlook) ───────────────────────────────────────────────
# Get a token via Microsoft Graph Explorer: https://developer.microsoft.com/graph/graph-explorer
# Or configure an Azure AD app and use PKCE OAuth
# Can also be set via the Integrations UI
MICROSOFT_ACCESS_TOKEN=
